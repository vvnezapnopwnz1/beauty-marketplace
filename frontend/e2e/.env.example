# ─── E2E Test Environment ─────────────────────────────
# Copy to .env and adjust for your setup

# Base URLs
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:8080
E2E_HEADED=0

# OTP code (dev mode uses fixed code)
E2E_OTP_CODE=1234

# Test user phones
E2E_OWNER_PHONE=+79001112233
E2E_MASTER_PHONE=+79001112244
E2E_ADMIN_PHONE=+79000000001

# Dev seed for real 2GIS claim bootstrap
E2E_SEED_SOURCE=2gis
E2E_SEED_EXTERNAL_ID=141373143068690
E2E_SEED_SNAPSHOT_NAME=Салон E2E

# Optional hard override (normally not needed because seed-salon returns salonId)
# E2E_SALON_ID=

# Scenario filtering
# E2E_TAG=smoke              # run only smoke tests
# E2E_TAG=critical-path      # run critical path tests
# E2E_SCENARIOS=scenarios/flows.yaml  # custom scenario file
